Import("env")

sdk_headers = [
    File("rgb_backlight.h"),
    File("cc1101_regs.h"),
]

# ST25R3916 not present on PN532-only boards
if "FURI_HAL_NFC_PN532_ONLY" not in env.get("CPPDEFINES", []):
    sdk_headers.extend(
        [
            File("st25r3916_reg.h"),
            File("st25r3916.h"),
        ]
    )

env.Append(
    CPPPATH=[
        "#/lib/drivers",
    ],
    SDK_HEADERS=sdk_headers,
    LINT_SOURCES=[
        Dir("."),
    ],
)


libenv = env.Clone(FW_LIB_NAME="hwdrivers")
libenv.ApplyLibFlags()

sources = Glob("*.c", source=True)

# Exclude ST25R3916 driver on PN532-only boards
if "FURI_HAL_NFC_PN532_ONLY" in env.get("CPPDEFINES", []):
    sources = [s for s in sources if "st25r3916" not in str(s)]

lib = libenv.StaticLibrary("${FW_LIB_NAME}", sources)
libenv.Install("${LIB_DIST_DIR}", lib)
Return("lib")
